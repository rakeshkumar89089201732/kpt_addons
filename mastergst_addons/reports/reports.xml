     <record id="action_part_b_eway_bill" model="ir.actions.report">
         <field name="name">E-Way Bill - Part B</field>
         <field name="model">account.move</field>
         <field name="report_type">qweb-pdf</field>
         <field name="report_name">mastergst_addons.report_eway_bill_partb</field>
         <field name="report_file">mastergst_addons.report_eway_bill_partb</field>
