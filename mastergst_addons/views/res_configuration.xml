<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <record id="inherit_res_configuration_setting_form" model="ir.ui.view">
       <field name="name">inherit.res.configuration.setting.form</field>
       <field name="model">res.config.settings</field>
       <field name="inherit_id" ref="l10n_in_edi_ewaybill.res_config_settings_view_form_inherit_l10n_in_edi_ewaybill"/>
       <field name="arch" type="xml">
            <xpath expr="//block[@id='india_localization']" position="after">
              <h2>E-way Bill Master GST</h2>
                <div class='row mt16 o_settings_container'>
                     <div class="content-group">
                                <div class="row mt16">
                                    <label for="mastergst_username" class="col-lg-4 o_light_label" string="Username"/>
                                    <field name="mastergst_username"/>
                                </div>
                                 <div class="row">
                                    <label for="mastergst_password" class="col-lg-4 o_light_label" string="Password"/>
                                    <field name="mastergst_password" password="True"/>
                                </div>
                                <div class="row">
                                    <label for="mastergst_client_id" class="col-lg-4 o_light_label" string="Client Id"/>
                                    <field name="mastergst_client_id"/>
                                </div>
                               <div class="row">
                                    <label for="mastergst_client_secret" class="col-lg-4 o_light_label" string="Client Secret"/>
                                    <field name="mastergst_client_secret"/>
                                </div>
                                <div class="row">
                                    <label for="ip_address" class="col-lg-4 o_light_label" string="ip_address"/>
                                    <field name="ip_address"/>
                                </div>
                          <div class='mt8'>
                                <button name="mastergst_edi_test" icon="fa-arrow-right" type="object" string="Authenticate the Mastergst" class="btn-link"/>
                            </div>
                </div>
                </div>
            </xpath>
       </field>
   </record>
</odoo>