<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="partb_form_view" model="ir.ui.view">
        <field name="name">partb.form.view</field>
        <field name="model">partb</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" state_visible="post,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Created Info">
                            <field name="company_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="created_date" readonly="1"/>
                        </group>
                        <group string="Eway Info">
                            <field name="invoice_no" readonly="1"/>
                            <field name="eway_no" readonly="1"/>
<!--                            <field name="entereddate" readonly="1"/>-->
                            <field name="ewaybilldate" readonly="1"/>
                            <field name="veupddate" readonly="1"/>
                            <field name="vehileno" readonly="1"/>
                            <field name="fromplace" readonly="1"/>
                            <field name="fromstate" readonly="1"/>
                        </group>
                        <group string="Transport Info">
                            <field name="reasoncode" readonly="1"/>
                            <field name="reasonrem" readonly="1"/>
                            <field name="transdocno" readonly="1"/>
                            <field name="transdocdate" readonly="1"/>
                            <field name="transmode" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="model_partb_tree_view" model="ir.ui.view">
        <field name="name">model.partb.tree.view</field>
        <field name="model">partb</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="created_date"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="company_id"/>
<!--                <field name="entereddate"/>-->
                <field name="vehileno"/>
                <field name="fromplace"/>
                <field name="fromstate"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_partb" model="ir.actions.act_window">
        <field name="name">Part-B</field>
        <field name="res_model">partb</field>
        <field name="view_mode">tree,form,pivot</field>
    </record>

     <menuitem id="multi_vehicle_root"
              name="Multivehicle Logs"
              sequence="5"
              parent="account.menu_finance"/>

    <menuitem id="partb_root"
              parent="multi_vehicle_root"
              name="PartB"
              action="action_partb"
              sequence="5"/>

</odoo>