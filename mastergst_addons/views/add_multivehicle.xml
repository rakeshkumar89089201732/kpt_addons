<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="model_add_multivehicle_form_view" model="ir.ui.view">
        <field name="name">model.add.multivehicle.form.view</field>
        <field name="model">add.multivehicle</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="post,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                         <group string="Created Info">
                            <field name="company_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="created_date" readonly="1"/>
                        </group>
                        <group string="E-Way Info">
                            <field name="invoice_no" readonly="1"/>
                            <field name="initiate_id" readonly="1"/>
                            <field name="ewbNo" readonly="1"/>
                            <field name="from_place" readonly="1"/>
                            <field name="vehicleNo" readonly="1"/>
                            <field name="groupNo" readonly="1"/>
                        </group>
                         <group string="vehicle Info">
                             <field name="vehAddedDate" readonly="1"/>
                            <field name="transDocNo" readonly="1"/>
                            <field name="transDocDate" readonly="1"/>
                            <field name="quantity" readonly="1"/>
                             <field name="vehicle_mode" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="model_add_multivehicle_tree_view" model="ir.ui.view">
        <field name="name">model.add.multivehicle.tree.view</field>
        <field name="model">add.multivehicle</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="created_date"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="company_id"/>
                <field name="invoice_no"/>
                <field name="ewbNo"/>
                <field name="vehicleNo"/>
                <field name="groupNo"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="action_add_multivehicle" model="ir.actions.act_window">
        <field name="name">Add Multivehicle</field>
        <field name="res_model">add.multivehicle</field>
        <field name="view_mode">tree,form,pivot</field>
    </record>

    <menuitem id="add_multivehicle_root"
              name="Add Multivehicle"
              action="action_add_multivehicle"
              parent="multi_vehicle_root"
              sequence="15"/>
</odoo>