<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="action_report_pro_forma_invoice_dispatch" model="ir.actions.report">
            <field name="name">KPT PRO-FORMA - Dispatch Team</field>
            <field name="model">sale.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">sale_order_extension.report_kpt_performa_invoice_dispatch</field>
            <field name="report_file">sale_order_extension.report_kpt_performa_invoice_dispatch</field>
            <field name="print_report_name">'PRO-FORMA - %s - Dispatch' % (object.name)</field>
            <field name="binding_model_id" ref="model_sale_order"/>
            <field name="binding_type">report</field>
            <field name="groups_id" eval="[(4, ref('sale.group_proforma_sales'))]"/>
        </record>

    <record id="action_report_pro_forma_invoice_kpt" model="ir.actions.report">
        <field name="name">Pro-Forma Invoice</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sale_order_extension.report_saleorder_pro_forma</field>
        <field name="report_file">sale_order_extension.report_saleorder_pro_forma</field>
        <field name="print_report_name">'Pro-Forma Invoice - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
        <field name="groups_id" eval="[(4, ref('sale.group_proforma_sales'))]"/>
    </record>
</odoo>