<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
        <record id="view_account_move_form_extension" model="ir.ui.view">
        <field name="name">account.move.view.form.extension</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='journal_div']" position="after">
                <field name="tax_invoice_ref" placeholder="Add Tax Invoice Reference" invisible="move_type != 'out_invoice'" readonly="state != 'draft'"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/tree/field[@name='product_uom_id']" position="after">
                <field name="product_packaging_qty" readonly="parent.state != 'draft'"/>
                <field name="product_packaging_id" readonly="parent.state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>