                            <th style="padding: 8px; border: 1px solid black;">Per</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="sequence" t-value="1"/>
                        <t t-foreach="doc.order_line.filtered(lambda x: x.product_id.detailed_type != 'service')"
                           t-as="line">
                            <tr t-if="not line.display_type and line.product_id.detailed_type != 'service'">
                                <td style=" text-align: center; border: 1px solid black;">
                                    <span t-esc="sequence"/>
                                </td>
                                <td style="text-align: start; border: 1px solid black;">
                                    <span style="margin-left:10px;" t-esc="line.name"/>
                                </td>
                                <td style="text-align: center; border: 1px solid black;">
                                    <span t-esc="line.product_template_id.l10n_in_hsn_code"/>
                                </td>
                                <td style="text-align: center; border: 1px solid black;">
                                    <span t-if="line.product_packaging_qty" t-esc="line.product_packaging_qty"
                                          t-options="{'widget': 'float', 'precision': 0}"/>
                                    <span t-esc="line.product_packaging_id.name"/>
                                </td>
                                <t t-if="line.product_id.detailed_type != 'service'">
                                    <td style="text-align: center; border: 1px solid black;">
                                        <span t-esc="'{:.2f}'.format(line.product_uom_qty)"/>&amp;nbsp;
                                        <span t-esc="line.product_uom.name"/>
                                    </td>
                                    <td style="text-align: center; border: 1px solid black;">
                                        <span t-esc="line.product_uom.name"/>
                                    </td>
                                </t>
                                <t t-else="">
                                    <td style=" text-align: center; border: 1px solid black;"></td>
                                    <td style=" text-align: center; border: 1px solid black;"></td>
                                </t>
                            </tr>
                            <tr t-if="line.display_type and line.product_id.detailed_type != 'service'">
                                <td style="border: 1px solid black;"/>
                                <td style="border: 1px solid black;padding-left:20px" colspan="10">

                                    <span style="white-space: pre;" t-esc="line.name"/>
                                </td>
                            </tr>

                            <t t-if="not line.display_type and line.product_id.detailed_type != 'service'"
                               t-set="sequence" t-value="sequence + 1"/>
                        </t>
                        <t t-set="is_service"
                           t-value="bool(doc.order_line.filtered(lambda x: x.product_id.detailed_type == 'service'))"/>
                        <tr t-if="is_service">
                            <td style="text-align: center; border: 1px solid black;">
                            </td>
                            <td style="text-align: end; font-style: italic; border: 1px solid black; margin-right:10px; padding:30px">
                                <t t-foreach="doc.order_line.filtered(lambda x: x.product_id.detailed_type == 'service')"
                                   t-as="line">
                                    <span style="margin-left:10px;" t-esc="line.name"/>
                                    <br/>
                                </t>
                            </td>
                            <td style="text-align: center; border: 1px solid black;"></td>
                            <td style="text-align: center; border: 1px solid black;"></td>
                            <td style="text-align: center; border: 1px solid black;"></td>
                            <td style="text-align: center; border: 1px solid black;"></td>
                        </tr>
                    </tbody>

                </table>
                <div class="oe_structure"></div>
                <table style="width: 100%; border-collapse: collapse;margin:1% 0%;">
                    <style>
                        p {
                        margin: 0;
                        padding: 0;
                        }
                    </style>
                    <tr>
                        <td style="width: 50%;">
                            <p>Company's PAN:
                                <span class="fw-bold"
                                      style="font_weight:600 !important;font-family: sans-serif !important; "
                                      t-esc="doc.company_id.partner_id.l10n_in_pan"/>
                            </p>
<!--                            <p>Remarks:-->
<!--                                <span t-esc="doc.note"/>-->
<!--                            </p>-->
                        </td>
                        <td style="width: 50%;">
                            <p style="font-weight: bold;">Company's Bank Details</p>
                            <p>A/c Holder's Name :
                                <span class="fw-bold"
                                      style="font_weight:600 !important;font-family: sans-serif !important; "
                                      t-if="doc.company_id.partner_id.bank_ids"
                                      t-esc="doc.company_id.partner_id.bank_ids[0].acc_holder_name"/>
                            </p>
                            <p>Bank Name :
                                <span class="fw-bold"
                                      style="font_weight:600 !important;font-family: sans-serif !important; "
                                      t-if="doc.company_id.partner_id.bank_ids and doc.company_id.partner_id.bank_ids[0].bank_id"
                                      t-esc="doc.company_id.partner_id.bank_ids[0].bank_id.name"/>
                            </p>
                            <p>A/c No. :
                                <span class="fw-bold"
                                      style="font_weight:600 !important;font-family: sans-serif !important; "
                                      t-if="doc.company_id.partner_id.bank_ids"
                                      t-esc="doc.company_id.partner_id.bank_ids[0].acc_number"/>
                            </p>
                            <p>Branch &amp; IFS Code :
                                <span class="fw-bold"
                                      style="font_weight:600 !important;font-family: sans-serif !important; "
                                      t-if="doc.company_id.partner_id.bank_ids"
                                      t-esc="doc.company_id.partner_id.bank_ids[0].ifsc_code"/>
                            </p>
                            <p>SWIFT Code :
                                <span class="fw-bold"
                                      style="font_weight:600 !important;font-family: sans-serif !important; "
                                      t-if="doc.company_id.partner_id.bank_ids"
                                      t-esc="doc.company_id.partner_id.bank_ids[0].swift_code"/>
                            </p>
                        </td>
                    </tr>
                </table>
                <table style="width: 100%; border-collapse: collapse;margin:1% 0%;">
                    <tr>
                        <p style="text-decoration: underline;">Declaration</p>
                        <p t-esc="doc.note">We declare that this invoice shows the actual price of the goods described and that all
                            particulars are true and correct.
                        </p>
                    </tr>
                    <tr>
                        <p style="font-weight: bold;right:0;">for KPT Piping System Pvt. Ltd.</p>
                    </tr>
                    <tr>
                        <br/>
                        <br/>
                        <br/>
                        <td style="width:40%;"></td>
                        <td style="width:40%;"></td>
                        <td style="width:20%;">Authorised Signatory</td>
                    </tr>

                </table>

                <div class="oe_structure"/>
            </div>
        </t>
    </template>

    <template id="report_kpt_performa_invoice_dispatch">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="sale_order_extension.report_kpt_performa_invoice_dispatch_document"
                   t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>