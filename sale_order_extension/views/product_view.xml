<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="product_template_inherit_form_view" model="ir.ui.view">
            <field name="name">product.template.form.sale.order.extension.inherit</field>
            <field name="model">product.template</field>
            <field name="priority">5</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='property_account_income_id']" position="before">
                    <field name="account_income_intrastate_id" groups="account.group_account_readonly" />
                    <field name="account_income_interstate_id" groups="account.group_account_readonly" />
                </xpath>
                <xpath expr="//field[@name='property_account_expense_id']" position="before">
                    <field name="account_expense_intrastate_id" groups="account.group_account_readonly" />
                    <field name="account_expense_interstate_id" groups="account.group_account_readonly" />
                </xpath>
            </field>
        </record>
</odoo>