<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        Bypass hr_attendance "own reader" rule for Manager (Team Data Only) users.
        base.group_user implies group_hr_attendance_own_reader, so all internal users get
        domain [('employee_id.user_id', '=', user.id)] which restricts to own attendance only.
        By adding this rule with domain (1=1) for our group, OR(own_reader, this_rule) = (1=1),
        so managers get global rules only; our _compute_domain then ANDs employee_id in allowed_ids.
        -->
        <record id="hr_attendance_rule_manager_team_access" model="ir.rule">
            <field name="name">Manager Team Access: Allow team attendances</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('manager_team_access.group_manager_team_access'))]"/>
        </record>
        <record id="hr_attendance_overtime_rule_manager_team_access" model="ir.rule">
            <field name="name">Manager Team Access: Allow team overtime</field>
            <field name="model_id" ref="hr_attendance.model_hr_attendance_overtime"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('manager_team_access.group_manager_team_access'))]"/>
        </record>
        <!--
        Bypass hr_contract "employee manager" rule for Manager (Team Data Only) users.
        hr_contract.group_hr_contract_employee_manager restricts contracts to:
        ['|', ('employee_id.parent_id.user_id', '=', user.id), ('employee_id.user_id', '=', user.id)]
        By adding this rule with domain (1=1) for our group, OR(employee_manager, this_rule) = (1=1),
        so managers get global rules only; our _compute_domain then ANDs employee_id in allowed_ids.
        -->
        <record id="hr_contract_rule_manager_team_access" model="ir.rule">
            <field name="name">Manager Team Access: Allow team contracts</field>
            <field name="model_id" ref="hr_contract.model_hr_contract"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('manager_team_access.group_manager_team_access'))]"/>
        </record>
        <!--
        Bypass hr_payroll "own reader" rule for Manager (Team Data Only) users.
        Similar to hr_attendance, this allows managers to see payslips of their team members.
        -->
        <record id="hr_payslip_rule_manager_team_access" model="ir.rule">
            <field name="name">Manager Team Access: Allow team payslips</field>
            <field name="model_id" ref="hr_payroll.model_hr_payslip"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('manager_team_access.group_manager_team_access'))]"/>
        </record>
    </data>
</odoo>
