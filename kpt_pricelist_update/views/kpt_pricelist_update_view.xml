<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpt_pricelist_update_wizard_form" model="ir.ui.view">
        <field name="name">kpt.pricelist.update.wizard.form</field>
        <field name="model">kpt.pricelist.update.wizard</field>
        <field name="arch" type="xml">
            <form string="Update Pricelist">
                <group>
                    <group>
                        <field name="date"/>
                        <field name="source_type"/>
                        <field name="base_pricelist_id" invisible="source_type != 'pricelist'" required="source_type == 'pricelist'"/>
                    </group>
                    <group>
                        <field name="operation"/>
                        <field name="update_type"/>
                        <field name="value"/>
                    </group>
                </group>
                <group>
                    <field name="category_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_update_pricelist" string="Create Updated Pricelist" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_kpt_pricelist_update_wizard" model="ir.actions.act_window">
        <field name="name">Update Pricelist</field>
        <field name="res_model">kpt.pricelist.update.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
    </record>

    <menuitem id="menu_kpt_pricelist_update"
              name="Update Pricelist"
              parent="sale.product_menu_catalog"
              action="action_kpt_pricelist_update_wizard"
              sequence="20"/>
</odoo>
