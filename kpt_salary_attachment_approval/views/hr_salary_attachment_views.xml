<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Extend the existing salary attachment form to add approval states and buttons -->
    <record id="view_hr_salary_attachment_form_kpt_approval" model="ir.ui.view">
        <field name="name">hr.salary.attachment.form.kpt.approval</field>
        <field name="model">hr.salary.attachment</field>
        <field name="inherit_id" ref="hr_payroll.hr_salary_attachment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <!-- Submit for approval when currently running -->
                <button name="action_submit_for_approval"
                        type="object"
                        string="Submit for Approval"
                        class="btn-secondary"
                        invisible="state != 'open'"/>

                <!-- Approve / Reject only when waiting for approval -->
                <button name="action_approve"
                        type="object"
                        string="Approve"
                        class="btn-primary"
                        invisible="state != 'to_approve'"/>

                <button name="action_reject"
                        type="object"
                        string="Reject"
                        class="btn-secondary"
                        invisible="state != 'to_approve'"/>
            </xpath>

            <!-- Show the new approval state in the statusbar -->
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">to_approve,open,close,cancel</attribute>
            </xpath>
        </field>
    </record>

    <!-- Extend Salary Attachment Type views to control visibility in PWA/mobile app -->
    <record id="view_hr_salary_attachment_type_form_kpt_mobile" model="ir.ui.view">
        <field name="name">hr.salary.attachment.type.form.kpt.mobile</field>
        <field name="model">hr.salary.attachment.type</field>
        <field name="inherit_id" ref="hr_payroll.hr_salary_attachment_type_view_form"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="show_in_mobile"/>
            </field>
        </field>
    </record>

    <record id="view_hr_salary_attachment_type_tree_kpt_mobile" model="ir.ui.view">
        <field name="name">hr.salary.attachment.type.tree.kpt.mobile</field>
        <field name="model">hr.salary.attachment.type</field>
        <field name="inherit_id" ref="hr_payroll.hr_salary_attachment_type_view_tree"/>
        <field name="arch" type="xml">
            <field name="code" position="after">
                <field name="show_in_mobile" optional="show"/>
            </field>
        </field>
    </record>
</odoo>

