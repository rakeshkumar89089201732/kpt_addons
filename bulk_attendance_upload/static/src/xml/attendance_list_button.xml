<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="web.ListView" t-inherit="web.ListView" t-inherit-mode="extension" owl="1">
        <xpath expr="//t[@t-set-slot='control-panel-always-buttons']" position="inside">
            <button 
                t-if="showCreateMonthlyAttendanceButton"
                type="button"
                class="btn btn-primary"
                t-on-click="() => this.onCreateMonthlyAttendance()"
                title="Create Monthly Attendance">
                <i class="fa fa-calendar-plus me-2"/>
                Create Monthly Attendance
            </button>
        </xpath>
    </t>
</templates>
