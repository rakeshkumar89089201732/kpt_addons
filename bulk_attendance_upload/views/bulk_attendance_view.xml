<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bulk_attendance_wizard_form" model="ir.ui.view">
        <field name="name">bulk.attendance.wizard.form</field>
        <field name="model">bulk.attendance.wizard</field>
        <field name="arch" type="xml">
            <form string="Bulk Attendance Upload">
                <sheet>
                    <group>
                        <group string="Configuration">
                            <field name="mode" widget="radio"/>
                            <field name="attendance_date" string="Reference Date" 
                                   help="For Monthly mode, this determines the Month and Year."/>
                        </group>
                        <group string="Default Times" invisible="mode == 'day'">
                            <field name="default_check_in" widget="float_time"/>
                            <field name="default_check_out" widget="float_time"/>
                        </group>
                    </group>
                    <group string="File Upload">
                        <field name="upload_file" filename="file_name"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <footer>
                        <button string="Import" name="action_import" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bulk_attendance_wizard" model="ir.actions.act_window">
        <field name="name">Bulk Attendance Upload</field>
        <field name="res_model">bulk.attendance.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu removed - functionality replaced by Create Monthly Attendance -->
    <!-- Button is now added via JavaScript template extension (attendance_list_button.js/xml) -->
</odoo>
