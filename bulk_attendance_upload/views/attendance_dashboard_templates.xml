<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="attendance_dashboard_template" name="Attendance Dashboard">
        <t t-call="web.layout">
            <t t-set="title">Attendance Dashboard</t>
            <style>
                html, body { overflow-x: hidden; overflow-y: auto; min-height: 100%; }
                .attendance-dashboard {
                    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
                    min-height: 100vh;
                    padding: 30px;
                    padding-bottom: 60px;
                }
                .dashboard-header {
                    margin-bottom: 35px;
                }
                .dashboard-header h1 {
                    font-size: 36px;
                    font-weight: 700;
                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                    margin-bottom: 8px;
                }
                .dashboard-header p {
                    color: #64748b;
                    font-size: 16px;
                    margin: 0;
                }
                .stat-card {
                    background: white;
                    border-radius: 12px;
                    padding: 16px 20px;
                    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07), 0 1px 3px rgba(0, 0, 0, 0.06);
                    transition: all 0.3s ease;
                    position: relative;
                    overflow: hidden;
                    display: flex;
                    flex-direction: column;
                    min-height: auto;
                }
                .stat-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    right: 0;
                    height: 4px;
                    background: var(--card-color);
                }
                .stat-card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1), 0 3px 6px rgba(0, 0, 0, 0.08);
                }
                .stat-card.card-blue { --card-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
                .stat-card.card-green { --card-color: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); }
                .stat-card.card-cyan { --card-color: linear-gradient(135deg, #06beb6 0%, #48b1bf 100%); }
                .stat-card.card-orange { --card-color: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
                .stat-card-icon {
                    width: 45px;
                    height: 45px;
                    border-radius: 10px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-size: 22px;
                    color: white;
                    background: var(--card-color);
                    margin-bottom: 10px;
                    flex-shrink: 0;
                }
                .stat-card-label {
                    color: #64748b;
                    font-size: 11px;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    margin-bottom: 8px;
                }
                .stat-card-value {
                    font-size: 28px;
                    font-weight: 700;
                    color: #1e293b;
                    margin: 0;
                    line-height: 1.1;
                }
                .chart-card, .list-card {
                    background: white;
                    border-radius: 16px;
                    padding: 25px;
                    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07), 0 1px 3px rgba(0, 0, 0, 0.06);
                }
                .chart-card h5, .list-card h5 {
                    font-size: 18px;
                    font-weight: 700;
                    color: #1e293b;
                    margin-bottom: 25px;
                    padding-bottom: 15px;
                    border-bottom: 2px solid #f1f5f9;
                }
                .employee-item {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    padding: 15px;
                    margin-bottom: 10px;
                    background: #f8fafc;
                    border-radius: 10px;
                    transition: all 0.2s ease;
                }
                .employee-item:hover {
                    background: #f1f5f9;
                    transform: translateX(5px);
                }
                .employee-rank {
                    width: 32px;
                    height: 32px;
                    border-radius: 8px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    font-weight: 700;
                    font-size: 14px;
                    color: white;
                    margin-right: 12px;
                }
                .employee-rank.rank-1 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
                .employee-rank.rank-2 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
                .employee-rank.rank-3 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
                .employee-rank.rank-other { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
                .employee-name {
                    font-weight: 600;
                    color: #1e293b;
                    flex: 1;
                }
                .employee-hours {
                    font-weight: 700;
                    color: #667eea;
                    font-size: 16px;
                }
                .stats-grid {
                    display: grid;
                    grid-template-columns: 1fr 1fr;
                    gap: 15px;
                }
                .stat-box {
                    text-align: center;
                    padding: 20px;
                    background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
                    border-radius: 12px;
                    border: 2px solid transparent;
                    transition: all 0.3s ease;
                }
                .stat-box:hover {
                    border-color: #667eea;
                    transform: scale(1.05);
                }
                .stat-box-value {
                    font-size: 32px;
                    font-weight: 700;
                    margin-bottom: 5px;
                }
                .stat-box.total-hours { color: #667eea; }
                .stat-box.overtime-hours { color: #f5576c; }
                .stat-box-label {
                    color: #64748b;
                    font-size: 12px;
                    font-weight: 600;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                }
                .action-buttons {
                    display: flex;
                    flex-direction: column;
                    gap: 12px;
                }
                .btn-modern {
                    padding: 14px 24px;
                    border-radius: 10px;
                    font-weight: 600;
                    text-decoration: none;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    gap: 10px;
                    transition: all 0.3s ease;
                    border: none;
                    cursor: pointer;
                }
                .btn-primary-modern {
                    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                    color: white;
                    box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
                }
                .btn-primary-modern:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.5);
                }
                .btn-outline-modern {
                    background: white;
                    color: #667eea;
                    border: 2px solid #667eea;
                }
                .btn-outline-modern:hover {
                    background: #667eea;
                    color: white;
                    transform: translateY(-2px);
                }
                .loading-spinner {
                    display: inline-block;
                    width: 20px;
                    height: 20px;
                    border: 3px solid rgba(102, 126, 234, 0.3);
                    border-radius: 50%;
                    border-top-color: #667eea;
                    animation: spin 1s ease-in-out infinite;
                }
                @keyframes spin {
                    to { transform: rotate(360deg); }
                }
                .pulse {
                    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
                }
                @keyframes pulse {
                    0%, 100% { opacity: 1; }
                    50% { opacity: .5; }
                }
                .card-link {
                    text-decoration: none;
                    color: inherit;
                    display: block;
                }
                .card-link:hover {
                    text-decoration: none;
                }
                .quick-actions-bar {
                    margin: 20px 0 25px 0;
                    display: flex;
                    justify-content: flex-start;
                }
                .chart-header-row {
                    display: flex;
                    align-items: center;
                    justify-content: space-between;
                    gap: 12px;
                }
                .chart-filter {
                    display: flex;
                    align-items: center;
                    gap: 6px;
                    font-size: 12px;
                    color: #64748b;
                }
                .chart-filter select {
                    border-radius: 999px;
                    border: 1px solid #cbd5f5;
                    padding: 4px 10px;
                    font-size: 12px;
                    color: #475569;
                    background: #f8fafc;
                    outline: none;
                }
            </style>
            <div class="o_action_manager">
                <div class="o_action o_view_controller">
                    <div class="o_controller">
                        <div class="attendance-dashboard">
                            <div class="dashboard-header">
                                <h1>Attendance Dashboard</h1>
                                <p>Real-time overview of employee attendance and performance metrics</p>
                            </div>

                            <!-- Top Quick Action -->
                            <div class="quick-actions-bar">
                                <a href="/web#action=hr_attendance.hr_attendance_action" class="btn-modern btn-primary-modern" style="min-width: 260px; justify-content: center;">
                                    <i class="fa fa-list"></i>
                                    <span>View All Attendances</span>
                                </a>
                            </div>

                            <!-- KPI Cards Row -->
                            <div id="dashboard_cards" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-bottom: 30px;">
                                <!-- Total Employees - click opens Employees list -->
                                <a href="/web#action=hr.open_view_employee_list" class="card-link">
                                    <div class="stat-card card-blue">
                                        <div style="display: flex; align-items: flex-start; gap: 12px;">
                                            <div class="stat-card-icon">
                                                <i class="fa fa-users"></i>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div class="stat-card-label">Total Employees</div>
                                                <h2 class="stat-card-value" id="card_total_employees">
                                                    <span class="loading-spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>
                                                </h2>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                                <!-- Today's Check-ins - click opens Attendances -->
                                <a href="/web#action=hr_attendance.hr_attendance_action" class="card-link">
                                    <div class="stat-card card-green">
                                        <div style="display: flex; align-items: flex-start; gap: 12px;">
                                            <div class="stat-card-icon">
                                                <i class="fa fa-check-circle"></i>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div class="stat-card-label">Today's Check-ins</div>
                                                <h2 class="stat-card-value" id="card_today_checkins">
                                                    <span class="loading-spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>
                                                </h2>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                                <!-- Currently at Work - click opens Attendances -->
                                <a href="/web#action=hr_attendance.hr_attendance_action" class="card-link">
                                    <div class="stat-card card-cyan">
                                        <div style="display: flex; align-items: flex-start; gap: 12px;">
                                            <div class="stat-card-icon">
                                                <i class="fa fa-clock-o"></i>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div class="stat-card-label">Currently at Work</div>
                                                <h2 class="stat-card-value" id="card_at_work">
                                                    <span class="loading-spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>
                                                </h2>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                                <!-- Week Hours - click opens Attendances -->
                                <a href="/web#action=hr_attendance.hr_attendance_action" class="card-link">
                                    <div class="stat-card card-orange">
                                        <div style="display: flex; align-items: flex-start; gap: 12px;">
                                            <div class="stat-card-icon">
                                                <i class="fa fa-hourglass-half"></i>
                                            </div>
                                            <div style="flex: 1; min-width: 0;">
                                                <div class="stat-card-label">Week Hours</div>
                                                <h2 class="stat-card-value" id="card_week_hours">
                                                    <span class="loading-spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>
                                                </h2>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Charts Row -->
                            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 30px;">
                                <!-- Daily chart no longer wrapped in link so filter is clickable -->
                                <div class="chart-card">
                                    <div class="chart-header-row">
                                        <h5 style="margin-bottom: 0;">
                                            <i class="fa fa-line-chart" style="margin-right: 10px; color: #667eea;"></i>
                                            <span>Daily Attendance</span>
                                        </h5>
                                        <div class="chart-filter">
                                            <span>Range:</span>
                                            <select id="daily_period_filter">
                                                <option value="7" selected="selected">Last 7 days</option>
                                                <option value="15">Last 15 days</option>
                                                <option value="30">Last 30 days</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div style="position: relative; height: 300px;">
                                        <canvas id="dailyChart"></canvas>
                                    </div>
                                </div>
                                <a href="/web#action=hr_attendance.hr_attendance_action" class="card-link">
                                    <div class="list-card">
                                        <h5><i class="fa fa-trophy" style="margin-right: 10px; color: #f5576c;"></i>Top Employees (This Week)</h5>
                                        <div id="top_employees_list">
                                            <div style="text-align: center; padding: 40px;">
                                                <div class="loading-spinner" style="margin: 0 auto 15px;"></div>
                                                <p style="color: #64748b; margin: 0;">Loading...</p>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>

                            <!-- Bottom Row -->
                            <div style="display: grid; grid-template-columns: 1fr; gap: 20px;">
                                <a href="/web#action=hr_attendance.hr_attendance_action" class="card-link">
                                    <div class="chart-card">
                                        <h5><i class="fa fa-calendar" style="margin-right: 10px; color: #667eea;"></i>Monthly Statistics</h5>
                                        <div class="stats-grid">
                                            <div class="stat-box total-hours">
                                                <div class="stat-box-value" id="card_month_hours">
                                                    <span class="loading-spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>
                                                </div>
                                                <div class="stat-box-label">Total Hours</div>
                                            </div>
                                            <div class="stat-box overtime-hours">
                                                <div class="stat-box-value" id="card_month_overtime">
                                                    <span class="loading-spinner" style="width: 16px; height: 16px; border-width: 2px;"></span>
                                                </div>
                                                <div class="stat-box-label">Overtime Hours</div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
            <script type="text/javascript" src="/bulk_attendance_upload/static/src/js/attendance_dashboard.js"></script>
        </t>
    </template>
</odoo>
