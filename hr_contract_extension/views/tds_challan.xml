<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_tds_challan_tree" model="ir.ui.view">
        <field name="name">tds.challan.tree</field>
        <field name="model">tds.challan</field>
        <field name="arch" type="xml">
            <tree string="TDS Challan" editable="top">
                <field name="company_id" optional="show"/>
                <field name="period_month" optional="show"/>
                <field name="tds_payment"/>
                <field name="surcharge"/>
                <field name="education_cess"/>
                <field name="higher_education_cess"/>
                <field name="interest"/>
                <field name="other"/>
                <field name="fee"/>
                <field name="cheque_dd_no"/>
                <field name="bsr_code"/>
                <field name="tax_deposit_date"/>
                <field name="challan_no"/>
                <field name="book_entry"/>
                <field name="minor_head"/>
            </tree>
        </field>
    </record>

    <record id="view_tds_challan_form" model="ir.ui.view">
        <field name="name">tds.challan.form</field>
        <field name="model">tds.challan</field>
        <field name="arch" type="xml">
            <form string="TDS Challan">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_autofill_from_hr_tds"
                                type="object"
                                string="Auto Fill from HR TDS"
                                class="oe_highlight"/>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="period_month"/>
                            <field name="tds_payment"/>
                            <field name="surcharge"/>
                            <field name="education_cess"/>
                            <field name="higher_education_cess"/>
                            <field name="interest"/>
                            <field name="other"/>
                            <field name="fee"/>
                        </group>

                        <group>
                            <field name="cheque_dd_no"/>
                            <field name="bsr_code"/>
                            <field name="tax_deposit_date"/>
                            <field name="challan_no"/>
                            <field name="book_entry"/>
                            <field name="minor_head"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="TDS Details" name="tds_details">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="employee_id"/>
                                    <field name="pan_no"/>
                                    <field name="tds_amount" sum="Total TDS"/>
                                    <field name="date"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- action_tds_challan defined in data/action_tds_challan.xml (loads first for hr_contract.xml ref). -->
    <menuitem id="menu_tds_challan" name="TDS Challans" parent="hr_payroll.menu_hr_payroll_employees_root" action="action_tds_challan" sequence="50"/>
    <!--
    TODO: Odoo 18 migration:
    Attempted to add Contracts dropdown entry, but parent menu hr_contract.menu_hr_contracts_root not present in this stack.
    Commented to avoid ParseError; revisit when proper parent menu is identified.
    <menuitem id="menu_tds_challan_contracts"
              name="TDS Challans"
              parent="hr_contract.menu_hr_contracts_root"
              action="action_tds_challan"
              sequence="55"/>
    -->
</odoo>
