            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = bool(contract and (contract.house_rent_allowance or 0.0))</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = contract.house_rent_allowance or 0.0</field>
            <field name="appears_on_payslip">True</field>
            <field name="active">True</field>
