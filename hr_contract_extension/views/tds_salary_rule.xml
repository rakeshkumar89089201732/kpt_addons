        </record>

        <record id="salary_rule_pf_employer_ded_from_contract" model="hr.salary.rule">
            <field name="name">EPF Employer contribution</field>
            <field name="code">PFEMP</field>
            <field name="sequence">171</field>
            <!-- When deduct_employer_pf_in_net_pay is checked, use DED category so it reduces Net Salary -->
            <!-- Otherwise use EMPC category so it shows but doesn't reduce net -->
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = bool(contract and contract.apply_pf and contract.deduct_employer_pf_in_net_pay and (contract.employer_pf_share or 0.0))</field>
