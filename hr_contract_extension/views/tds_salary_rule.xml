            <field name="struct_id" ref="hr_payroll.structure_002"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = bool(contract and contract.apply_pf and contract.deduct_employee_pf_in_net_pay and (contract.employee_provident_fund or 0.0))</field>
