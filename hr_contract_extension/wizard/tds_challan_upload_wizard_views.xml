<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tds_challan_upload_wizard_form" model="ir.ui.view">
        <field name="name">tds.challan.upload.wizard.form</field>
        <field name="model">tds.challan.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload TDS Details">
                <group>
                    <field name="file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <div class="text-muted">
                    <p>Expected Excel Columns:</p>
                    <ul>
                        <li>Column A: Employee Code (Registration Number)</li>
                        <li>Column B: PAN (Optional, used for lookup if Code fails)</li>
                        <li>Column C: TDS Amount</li>
                        <li>Column D: Date (Optional, defaults to Challan Month)</li>
                    </ul>
                </div>
                <footer>
                    <button name="action_upload" string="Upload" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tds_challan_upload_wizard" model="ir.actions.act_window">
        <field name="name">Upload TDS Details</field>
        <field name="res_model">tds.challan.upload.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
