<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_salary_sheet_wizard_form" model="ir.ui.view">
        <field name="name">employee.salary.sheet.wizard.form</field>
        <field name="model">employee.salary.sheet.wizard</field>
        <field name="arch" type="xml">
            <form string="Salary Sheet">
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="salary_sheet_attachment_count" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Generate Salary Sheet" name="action_generate" type="object" class="btn-primary"/>
                    <button string="Salary Sheets" name="action_open_saved" type="object" class="btn-secondary"/>
                    <button string="Close" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_employee_salary_sheet_wizard" model="ir.actions.act_window">
        <field name="name">Salary Sheet</field>
        <field name="res_model">employee.salary.sheet.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_employee_id': active_id}</field>
    </record>
</odoo>
