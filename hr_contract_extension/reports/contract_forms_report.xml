                                    <tr>
                                        <td class="label">Wage (Basic)</td>
                                        <td class="value">: <t t-esc="o.wage or 0.0"/></td>
                                    </tr>
                                    <tr>
                                        <td class="label">Gross</td>
                                        <td class="value">: <t t-esc="o.gross or 0.0"/></td>
                                    </tr>
                                </table>
                            </div>

                            <div class="box">
                                <div class="muted" style="margin-bottom:6px;">Nominee / Family details (fill as required)</div>
                                <table>
                                    <tr>
                                        <th style="width:30%;">Field</th>
                                        <th>Value</th>
                                    </tr>
                                    <tr>
                                        <td>Nominee Name</td>
                                        <td><t t-esc="o.form_nominee_name or ''"/></td>
                                    </tr>
                                    <tr>
                                        <td>Relation</td>
                                        <td><t t-esc="o.form_nominee_relation or ''"/></td>
                                    </tr>
                                    <tr>
                                        <td>Date of Birth</td>
                                        <td><t t-esc="o.form_nominee_dob or ''"/></td>
                                    </tr>
                                    <tr>
                                        <td>Address</td>
                                        <td><t t-esc="o.form_nominee_address or ''"/></td>
                                    </tr>
                                </table>
                            </div>

                            <table class="sign">
                                <tr>
                                    <td style="width:50%;">Place: <t t-esc="o.form15_place or ''"/></td>
                                    <td style="width:50%;">Signature (Employee)</td>
                                </tr>
                                <tr>
                                    <td>Date: <t t-esc="o.form15_date or ''"/></td>
                                    <td>Signature (Employer)</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </template>

