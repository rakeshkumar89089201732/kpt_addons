                            <table class="sign">
                                <tr>
                                    <td style="width:50%;">Place: <t t-esc="o.form23_place or ''"/></td>
                                    <td style="width:50%;">Signature (Employee)</td>
                                </tr>
                                <tr>
                                    <td>Date: <t t-esc="o.form23_date or ''"/></td>
